# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# Google Drive
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_parent_folder_id

# Google Service Account
# LOCAL DEV:  path to your service account JSON file, e.g. service_account.json
# RAILWAY:    paste the full JSON content directly as the value
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json
